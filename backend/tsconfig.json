{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",

    "target": "ES2020",
    "outDir": "./dist",
    "rootDir": "./src",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "incremental": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}